# Exegol IHE — Environment Variables
# Copy this file to .env and fill in the values you need.

# ── AI Provider API Keys ──────────────────────────────────────
# Configure these in Settings > Providers within the UI.
# You can also set them here for convenience.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# ── AWS Bedrock (optional) ────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=...

# ── Azure OpenAI (optional) ──────────────────────────────────
# AZURE_RESOURCE_NAME=...

# ── Models.dev API (model metadata) ──────────────────────────
# EXEGOL_IHE_MODELS_URL=https://models.dev
